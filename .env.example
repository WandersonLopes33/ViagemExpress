NODE_ENV=production
PORT=3002

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO
DB_HOST=localhost
DB_PORT=5432
DB_NAME=NOME_DO_BANCO
DB_USER=USUARIO
DB_PASSWORD=SENHA
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_ENABLED=false

# LLM (Groq)
LLM_PROVIDER=groq
GROQ_API_KEY=sua_chave_groq_aqui         # Obtenha em: https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8000
GROQ_TEMPERATURE=0.7

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE_NAME=NomeDaInstancia

# Webhook
WEBHOOK_URL=http://localhost:3002/webhook

# Segurança
SESSION_SECRET=gere_uma_string_aleatoria_de_32_caracteres
JWT_SECRET=gere_outra_string_aleatoria_de_32_caracteres
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# IA
MAX_CONVERSATION_HISTORY=10
AI_REQUEST_TIMEOUT=30000
AI_MAX_RETRIES=2

# Logs
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true

# Horário de Atendimento
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
AI_TONE=friendly

# Funcionalidades
FEATURE_AUTO_TRANSFER_TO_HUMAN=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_AI_FALLBACK_ENABLED=true

# Empresa
COMPANY_NAME=Nome da Empresa
SUPPORT_EMAIL=contato@empresa.com.br
SUPPORT_PHONE=+5511999999999
CALENDLY_LINK=https://calendly.com/sua-agenda
